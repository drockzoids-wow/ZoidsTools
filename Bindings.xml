<Bindings>
    <Binding name="CLICK ZoidsToolsSmartMountButton:LeftButton" category="ZoidsTools" header="ZOIDSTOOLS">
        ZoidsToolsSmartMountButton:Click("LeftButton")
    </Binding>

    <Binding name="CLICK ZoidsToolsRepairMountButton:LeftButton" category="ZoidsTools">
        ZoidsToolsRepairMountButton:Click("LeftButton")
    </Binding>

    <Binding name="CLICK ZoidsToolsAuctionHouseMountButton:LeftButton" category="ZoidsTools">
        ZoidsToolsAuctionHouseMountButton:Click("LeftButton")
    </Binding>

    <Binding name="CLICK ZoidsToolsRideAlongMountButton:LeftButton" category="ZoidsTools">
        ZoidsToolsRideAlongMountButton:Click("LeftButton")
    </Binding>

    <Binding name="CLICK ZoidsToolsRandomHearthstoneButton:LeftButton" category="ZoidsTools">
        ZoidsToolsRandomHearthstoneButton:Click("LeftButton")
    </Binding>

    <Binding name="CLICK ZoidsToolsQuestItemButton:LeftButton" category="ZoidsTools">
        ZoidsToolsQuestItemButton:Click("LeftButton")
    </Binding>

    <Binding name="ZOIDSTOOLS_MATCH_TARGET_MOUNT" category="ZoidsTools">
        if ZoidsToolsMounts and ZoidsToolsMounts.MatchTargetMount then
            ZoidsToolsMounts.MatchTargetMount()
        end
    </Binding>
</Bindings>
